# Git Line Ending Configuration
# Ensures consistent line endings across Windows/Linux

# Auto detect text files and normalize to LF
* text=auto

# Force LF for specific files (even on Windows)
*.sh text eol=lf
*.py text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Force CRLF for Windows-specific files
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files (no line ending conversion)
*.db binary
*.sqlite binary
*.sqlite3 binary
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.tar binary
*.gz binary
